# 复制为 .env 并填入你自己的值
# cp .env.example .env

# 鉴权 token（自己随便生成一个长随机串）。
# iOS App 的 Config.swift authToken 必须和这里一致。
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN=

# 监听端口
PORT=3000

# 文件下载基址（App 文件卡/视频卡点击时从这里拉）。
# 填你服务器对外可访问的地址，结尾带 /file
FILE_BASE=http://YOUR_SERVER_HOST:3000/file

# agent 工作目录：你的 claude-home-agent 部署路径
# （CLAUDE.md / memory / 各种工具所在）。见 https://github.com/aaaa-zhen/claude-home-agent
AGENT_DIR=/home/youruser/claude-home-agent

# 模型（可选，默认读 AGENT_DIR/model.txt，再默认 claude-opus-4-8）
# CLAUDE_MODEL=claude-opus-4-8
